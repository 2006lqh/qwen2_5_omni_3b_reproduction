+    def _to_mono_audio(self, audio):
+        audio = np.asarray(audio)
+        if audio.ndim == 2:
+            if audio.shape[0] <= audio.shape[1]:
+                audio = audio.mean(axis=0)
+            else:
+                audio = audio.mean(axis=1)
+        return np.asarray(audio).squeeze().astype(np.float32)
+
+    def resample_audio(self, audio: np.ndarray, current_sample_rate: int):
+        audio = self._to_mono_audio(audio)
+        if current_sample_rate != 16000 and isinstance(audio, np.ndarray):
+            audio = librosa.resample(audio, orig_sr=current_sample_rate, target_sr=16000).astype(np.float32)
+        return audio
+
+    def _check_if_video_has_audio(self, video_path):
+        clip = VideoFileClip(video_path)
+        return clip.audio is not None
+
+    def _audio_decoder_to_dict(self, audio_decoder):
+        samples = audio_decoder.get_all_samples()
+        audio = samples.data
+        if hasattr(audio, "cpu"):
+            audio = audio.cpu().numpy()
+        return {"array": audio, "sampling_rate": samples.sample_rate}
+
+    def _model_input_device(self):
+        for parameter in self.model.parameters():
+            return parameter.device
+        return self.device
+
+    def _module_device(self, module):
+        for parameter in module.parameters():
+            return parameter.device
+        return self._model_input_device()
+
+    def _move_inputs_to_module_devices(self, inputs):
+        thinker = getattr(self.model, "thinker", self.model)
+        text_device = self._module_device(thinker.get_input_embeddings())
+        audio_device = self._module_device(getattr(thinker, "audio_tower", thinker))
+        vision_device = self._module_device(getattr(thinker, "visual", thinker))
+        audio_keys = {"input_features", "feature_attention_mask"}
+        vision_keys = {"pixel_values", "image_grid_thw", "pixel_values_videos", "video_grid_thw"}
+
+        for key, value in list(inputs.items()):
+            if not torch.is_tensor(value):
+                continue
+            if key in audio_keys:
+                target_device = audio_device
+            elif key in vision_keys:
+                target_device = vision_device
+            else:
+                target_device = text_device
+            target_dtype = self.model.dtype if torch.is_floating_point(value) else value.dtype
+            inputs[key] = value.to(device=target_device, dtype=target_dtype)
+        return inputs
     
